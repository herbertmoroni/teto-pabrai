<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_soft"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ============ INPUT CARD (always visible) ============ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_white"
            android:padding="14dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_ticker"
                android:textColor="@color/text_subtle"
                android:textSize="10sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/tickerInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_ticker"
                android:background="@drawable/bg_input"
                android:padding="12dp"
                android:textSize="16sp"
                android:fontFamily="monospace"
                android:inputType="textCapCharacters"
                android:maxLines="1" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp"
                android:weightSum="2">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_eps"
                        android:textColor="@color/text_subtle"
                        android:textSize="10sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />

                    <EditText
                        android:id="@+id/epsInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/hint_eps"
                        android:background="@drawable/bg_input"
                        android:padding="12dp"
                        android:textSize="14sp"
                        android:fontFamily="monospace"
                        android:inputType="numberDecimal"
                        android:maxLines="1" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_price"
                        android:textColor="@color/text_subtle"
                        android:textSize="10sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />

                    <EditText
                        android:id="@+id/priceInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/hint_price"
                        android:background="@drawable/bg_input"
                        android:padding="12dp"
                        android:textSize="14sp"
                        android:fontFamily="monospace"
                        android:inputType="numberDecimal"
                        android:maxLines="1" />
                </LinearLayout>
            </LinearLayout>

            <Button
                android:id="@+id/analyzeButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/action_analyze"
                android:textColor="@color/white"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/bg_button_primary"
                android:layout_marginTop="12dp"
                android:padding="12dp"
                android:stateListAnimator="@null" />

            <TextView
                android:id="@+id/inputHelper"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/input_helper"
                android:textColor="@color/text_subtle"
                android:textSize="10sp"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- ============ INTRO CONTAINER (visible state A) ============ -->
        <LinearLayout
            android:id="@+id/introContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

            <!-- Intro hero -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_hero_gradient"
                android:padding="18dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/brand_label"
                    android:textColor="@color/white_60"
                    android:textSize="10sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.15"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/intro_title"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/intro_subtitle"
                    android:textColor="@color/white_60"
                    android:textSize="12sp"
                    android:lineSpacingMultiplier="1.4" />
            </LinearLayout>

            <!-- How it works -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_white"
                android:padding="14dp"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/how_title"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="6dp">
                    <TextView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:text="1"
                        android:textColor="@color/indigo_primary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@drawable/bg_step_number"
                        android:layout_marginEnd="10dp" />
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/how_step_1"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="6dp">
                    <TextView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:text="2"
                        android:textColor="@color/indigo_primary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@drawable/bg_step_number"
                        android:layout_marginEnd="10dp" />
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/how_step_2"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="6dp">
                    <TextView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:text="3"
                        android:textColor="@color/indigo_primary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@drawable/bg_step_number"
                        android:layout_marginEnd="10dp" />
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/how_step_3"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- The method -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_white"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/method_title"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/method_text"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:lineSpacingMultiplier="1.5"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/method_formula"
                    android:textColor="@color/indigo_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:padding="10dp"
                    android:background="@drawable/bg_formula_box" />
            </LinearLayout>
        </LinearLayout>

        <!-- ============ RESULT CONTAINER (visible state B) ============ -->
        <LinearLayout
            android:id="@+id/resultContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Result hero -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_hero_gradient"
                android:padding="16dp"
                android:layout_marginBottom="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/resultTicker"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="TSM"
                        android:textColor="@color/white"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/resultStatusPill"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="22% below"
                        android:textColor="@color/white"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:background="@drawable/bg_pill_glass" />
                </LinearLayout>

                <TextView
                    android:id="@+id/resultSector"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Semiconductors · Monopoly"
                    android:textColor="@color/white_60"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_glass_block"
                        android:padding="9dp"
                        android:layout_marginEnd="3dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/hero_label_current"
                            android:textColor="@color/white_60"
                            android:textSize="9sp"
                            android:textAllCaps="true" />
                        <TextView
                            android:id="@+id/resultCurrentPrice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$168.42"
                            android:textColor="@color/white"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_glass_block"
                        android:padding="9dp"
                        android:layout_marginStart="3dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/hero_label_ceiling"
                            android:textColor="@color/white_60"
                            android:textSize="9sp"
                            android:textAllCaps="true" />
                        <TextView
                            android:id="@+id/resultCeilingPrice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$352.00"
                            android:textColor="@color/white"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Thesis card -->
            <LinearLayout
                android:id="@+id/thesisCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_white"
                android:padding="14dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="@string/result_thesis_title"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/result_thesis_sub"
                        android:textColor="@color/text_subtle"
                        android:textSize="10sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/resultThesis"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="TSMC is the world's dominant contract chip manufacturer below 5nm. No credible competitor at the leading edge — structural monopoly with massive capex moats. EPS growth tied to AI and HPC demand, with high ROIC. Geopolitical discount overstates relocation risk given customer lock-in."
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:lineSpacingMultiplier="1.5" />
            </LinearLayout>

            <!-- Math card -->
            <LinearLayout
                android:id="@+id/mathCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_white"
                android:padding="14dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/result_math_title"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="6dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="@string/math_eps"
                        android:textColor="@color/text_muted"
                        android:textSize="11sp" />
                    <TextView
                        android:id="@+id/mathEpsValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$22.00"
                        android:textColor="@color/text_primary"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/border_subtle" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="6dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="@string/math_multiple"
                        android:textColor="@color/text_muted"
                        android:textSize="11sp" />
                    <TextView
                        android:id="@+id/mathMultipleValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="× 20"
                        android:textColor="@color/text_primary"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/border_subtle" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="6dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="@string/math_fair_value"
                        android:textColor="@color/text_muted"
                        android:textSize="11sp" />
                    <TextView
                        android:id="@+id/mathFairValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$440.00"
                        android:textColor="@color/text_primary"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/border_subtle" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="6dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="@string/math_discount"
                        android:textColor="@color/text_muted"
                        android:textSize="11sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/math_discount_value"
                        android:textColor="@color/text_primary"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="10dp"
                    android:background="@drawable/bg_ceiling_highlight"
                    android:layout_marginTop="6dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="@string/math_ceiling"
                        android:textColor="@color/ceiling_fg"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textAllCaps="true" />
                    <TextView
                        android:id="@+id/mathCeilingValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$352.00"
                        android:textColor="@color/ceiling_fg"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Checklist card -->
            <LinearLayout
                android:id="@+id/checklistCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_white"
                android:padding="14dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/result_checklist_title"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:id="@+id/checklistContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>

            <Button
                android:id="@+id/shareButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/result_share"
                android:textColor="@color/white"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="@drawable/bg_button_share"
                android:padding="14dp"
                android:stateListAnimator="@null" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>